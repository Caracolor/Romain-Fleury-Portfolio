# Clé API Anthropic — à récupérer sur console.anthropic.com
ANTHROPIC_API_KEY=

# ID du Google Sheet de logging — visible dans l'URL du sheet
# Exemple : https://docs.google.com/spreadsheets/d/SHEET_ID_ICI/edit
GOOGLE_SHEET_ID=

# Credentials du compte de service Google — JSON complet en une seule ligne
# Crée un compte de service sur console.cloud.google.com, active l'API Sheets,
# génère une clé JSON et colle son contenu ici (les \n doivent rester littéraux)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Posthog Analytics
# Clé publique du projet — à récupérer sur app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
# Host EU de PostHog (ne pas modifier sauf si tu changes de région)
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
